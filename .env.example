# Copy this file to `.env` and paste your **freshly-rotated** OpenAI key.
# The real `.env` file is gitignored — it must NEVER be committed.

OPENAI_API_KEY=sk-proj-paste-your-rotated-key-here

# Default image model for medical photoreal diagrams.
# Options: gpt-image-1 (best for labels), dall-e-3 (alternative)
OPENAI_IMAGE_MODEL=gpt-image-1

# Default size for landscape diagrams (poison cards, anatomy panels)
OPENAI_IMAGE_SIZE=1536x1024
